# Copy to .env and fill in to point the Polygon RPC scripts (q1, q4) at
# the canonical polygon-rpc.com gateway. The free tier is enough for these
# scripts; sign up and grab a key at https://polygon.technology/developers
# (look for the "Polygon RPC" service / Polygon PoS).
#
# Leaving this blank causes the scripts to fall back to
# polygon-bor-rpc.publicnode.com, which is uncredentialed and works fine
# for read-only calls.
POLYGON_RPC_URL=
