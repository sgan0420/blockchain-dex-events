# Copy to .env and fill in to point the Polygon RPC scripts (q1, q4) at
# the canonical polygon-rpc.com gateway. polygon-rpc.com is operated by
# Ankr — visiting https://polygon-rpc.com/ routes you to their signup,
# and the keyed URL you get back is path-based on rpc.ankr.com (NOT a
# ?apikey= query string on polygon-rpc.com itself).
#
# Leaving this blank causes the scripts to fall back to
# polygon-bor-rpc.publicnode.com, which is uncredentialed and works fine
# for read-only calls.
POLYGON_RPC_URL=https://rpc.ankr.com/polygon/YOUR_KEY_HERE
